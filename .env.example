# ─── Camera 1 (Kasa EC70) ────────────────────────────────────────────────────
CAM1_IP=192.168.1.10
CAM1_PORT=19443
# URL-percent-encoded email address (@ → %40)
CAM1_USER=yourname%40example.com
# Base64-encoded password (echo -n 'yourpassword' | base64)
CAM1_PASS=eW91cnBhc3N3b3Jk

# ─── Camera 2 (Kasa EC70) ────────────────────────────────────────────────────
CAM2_IP=192.168.1.11
CAM2_PORT=19443
CAM2_USER=yourname%40example.com
CAM2_PASS=eW91cnBhc3N3b3Jk

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=catmonitor
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=catmonitor

# ─── nano-llm (VILA1.5-3b on Jetson) ─────────────────────────────────────────
# Match your JetPack version:
#   JetPack 6.x (L4T r36): dustynv/nano_llm:r36.2.0
#   JetPack 5.1 (L4T r35): dustynv/nano_llm:r35.4.1
NANO_LLM_IMAGE=dustynv/nano_llm:r36.2.0
VILA_MODEL=Efficient-Large-Model/VILA1.5-3b
MAX_NEW_TOKENS=96

# ─── cat-observer ─────────────────────────────────────────────────────────────
# Comma-separated go2rtc stream names (must match config.yaml.tpl)
CAMERAS=living_room,bedroom
# Seconds between frame grabs per camera
POLL_INTERVAL=30
# Pixel-diff sensitivity: lower = more sensitive to motion (range 0.0–1.0)
MOTION_THRESHOLD=0.02
OBSERVER_PORT=8088
LOG_LEVEL=INFO
