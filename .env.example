# ─── Camera 1 (Kasa EC70) ────────────────────────────────────────────────────
CAM1_IP=192.168.1.10
CAM1_PORT=19443
# URL-percent-encoded email address (@ → %40)
CAM1_USER=yourname%40example.com
# Base64-encoded password (echo -n 'yourpassword' | base64)
CAM1_PASS=eW91cnBhc3N3b3Jk

# ─── Camera 2 (Kasa EC70) ────────────────────────────────────────────────────
CAM2_IP=192.168.1.11
CAM2_PORT=19443
CAM2_USER=yourname%40example.com
CAM2_PASS=eW91cnBhc3N3b3Jk

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=catmonitor
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=catmonitor

# ─── MQTT (Mosquitto) ─────────────────────────────────────────────────────────
MQTT_USER=catmonitor
MQTT_PASSWORD=change_me_mqtt

# ─── Frigate ──────────────────────────────────────────────────────────────────
# Password used to protect Frigate's RTSP re-stream (can be any random string)
FRIGATE_RTSP_PASSWORD=change_me_rtsp
# Must match MQTT_USER / MQTT_PASSWORD above
FRIGATE_MQTT_USER=catmonitor
FRIGATE_MQTT_PASSWORD=change_me_mqtt

# ─── Ollama (external — already running on Jetson) ────────────────────────────
OLLAMA_URL=http://192.168.1.x:11434
OLLAMA_VISION_MODEL=moondream

# ─── cat-observer ─────────────────────────────────────────────────────────────
OBSERVER_PORT=8088
LOG_LEVEL=INFO
